# swipe.config — Offer Book Squad
# Config lido por scripts/swipe-indexer.py para indexar swipe/ e validar proveniência.
# Formato YAML. Mantém o swipe LEGAL: estrutura e padrões originais, nunca copy protegida colada.

version: "1.0.0"
updated: "2026-06-02"

# ── Taxonomia de categorias do swipe/ (espelha as 12 pastas) ──────────
categories:
  - { id: offers,            dir: swipe/offers,            label: "Ofertas irresistíveis (estrutura)" }
  - { id: headlines-hooks,   dir: swipe/headlines-hooks,   label: "Manchetes & ganchos" }
  - { id: leads-openers,     dir: swipe/leads-openers,     label: "Aberturas por tipo de lead" }
  - { id: vsl-webinar,       dir: swipe/vsl-webinar,       label: "Estruturas de VSL/webinar" }
  - { id: email-sms,         dir: swipe/email-sms,         label: "Sequências & subject lines" }
  - { id: mailers,           dir: swipe/mailers,           label: "Mala-direta & inserts" }
  - { id: ads,               dir: swipe/ads,               label: "Criativos por ângulo" }
  - { id: guarantees,        dir: swipe/guarantees,        label: "Garantias & reversão de risco" }
  - { id: scarcity-urgency,  dir: swipe/scarcity-urgency,  label: "Gatilhos VERDADEIROS de escassez" }
  - { id: ctas,              dir: swipe/ctas,              label: "Chamadas para ação" }
  - { id: affiliate,         dir: swipe/affiliate,         label: "Swipe para afiliados" }
  - { id: sales-letters,     dir: swipe/sales-letters,     label: "Cartas de venda longas (estrutura)" }

# ── Fontes externas catalogadas (proveniência) ───────────────────────
sources:
  internal: data/winners            # controls vencedores próprios → viram swipe
  external_index: swipe-sources/source-catalog.md
  attribution_log: swipe-sources/attribution-log.md

# ── Regras anti-plágio (enforçadas por scripts/citation-checker.py) ───
rules:
  verbatim_quote_max_words: 25       # citação literal atribuída ≤ 25 palavras
  store: ["structure", "anatomy", "principles", "original-patterns", "links"]
  forbid: ["pasted-copyrighted-copy", "full-ad-reproduction"]
  every_entry_requires: ["source", "structural-breakdown", "why-it-works", "reusable-pattern"]

# ── Índice gerado (saída do swipe-indexer) ───────────────────────────
index_output: data/registries/swipe-registry.md
